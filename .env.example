# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — never expose to the browser

# Public images (only if using imgbb instead of a public Supabase bucket)
IMGBB_API_KEY=                    # server only

# Site — drives canonical / Open Graph / JSON-LD URLs.
# Local: keep localhost. Production (Vercel): https://it-hatch.vercel.app
# If unset, the app defaults to the production URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
